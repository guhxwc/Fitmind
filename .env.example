# PostHog (analytics)
# Pegue em https://us.posthog.com → Project Settings → Project API Key
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Set como "1" para habilitar PostHog em localhost durante dev.
# Por padrão (0), eventos em localhost são ignorados para não poluir produção.
VITE_POSTHog_DEBUG=0

# ---------------------------------------------------------------
# As variáveis abaixo já existiam — mantidas aqui para referência.
# ---------------------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
